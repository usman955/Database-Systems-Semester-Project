<%- include('../partials/navbar') %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Recycling Bins Overview</h1>
  <p class="text-sm text-gray-600 mt-1">Monitor the fill levels of recycling bins across the campus.</p>
</div>

<% const fullBinsCount = bins.filter(b => b.current_fill_level >= 80).length; %>
<% if (fullBinsCount > 0) { %>
  <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-6 shadow-sm rounded-md">
    <div class="flex">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="ml-3">
        <p class="text-sm text-red-700 font-bold">
          There are <%= fullBinsCount %> bin(s) that are 80% full or more and require attention.
        </p>
      </div>
    </div>
  </div>
<% } %>

<div class="bg-white shadow overflow-hidden sm:rounded-lg border border-gray-100">
  <div class="flex flex-col">
    <div class="-my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
      <div class="py-2 align-middle inline-block min-w-full sm:px-6 lg:px-8">
        <div class="overflow-hidden">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Location</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Bin Code</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fill Level</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                <% if (locals.user && locals.user.role === 'admin') { %>
                  <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                <% } %>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% bins.forEach(bin => { %>
                <tr>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= bin.location_name %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= bin.category_name %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= bin.bin_code %></td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="flex items-center">
                      <span class="mr-2 text-sm text-gray-700 font-medium w-8 text-right"><%= bin.current_fill_level %>%</span>
                      <div class="w-full bg-gray-200 rounded-full h-2.5 max-w-xs min-w-[100px]">
                        <% let colorClass = 'bg-green-500'; 
                           if (bin.current_fill_level >= 60 && bin.current_fill_level < 80) colorClass = 'bg-yellow-500';
                           if (bin.current_fill_level >= 80) colorClass = 'bg-red-500';
                        %>
                        <div class="<%= colorClass %> h-2.5 rounded-full transition-all duration-500" style="width: <%= bin.current_fill_level %>%"></div>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% if (bin.status === 'Operational') { %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800 border border-green-200"><%= bin.status %></span>
                    <% } else if (bin.status === 'Full') { %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800 border border-red-200"><%= bin.status %></span>
                    <% } else { %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800 border border-gray-200"><%= bin.status %></span>
                    <% } %>
                  </td>
                  <% if (locals.user && locals.user.role === 'admin') { %>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
                      <form action="/bins/<%= bin.bin_id %>/update" method="POST" class="inline-block">
                        <input type="number" name="fill_level" value="<%= bin.current_fill_level %>" min="0" max="100" class="w-16 border-gray-300 rounded text-sm p-1 border shadow-sm focus:ring-green-500 focus:border-green-500">
                        <button type="submit" class="text-blue-600 hover:text-blue-900 ml-1 font-medium bg-blue-50 px-2 py-1 rounded">Update</button>
                      </form>
                      <form action="/bins/<%= bin.bin_id %>/empty" method="POST" class="inline-block">
                        <button type="submit" class="text-green-700 hover:text-green-900 ml-2 border border-green-600 bg-green-50 rounded px-2 py-1 font-medium transition duration-150 shadow-sm hover:bg-green-100">Empty Bin</button>
                      </form>
                    </td>
                  <% } %>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
