<%- include('partials/navbar') %>

<div class="bg-white shadow sm:rounded-lg max-w-3xl mx-auto mt-8">
  <div class="px-4 py-8 sm:p-10 text-center">
    <svg class="mx-auto h-16 w-16 text-red-500 mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
    </svg>
    <h3 class="text-2xl leading-6 font-bold text-gray-900 mb-4">
      <%= message || 'An error occurred' %>
    </h3>
    <div class="mt-4 max-w-2xl text-sm text-gray-500 mx-auto">
      <p class="text-lg font-medium"><%= error?.status || 500 %> Error</p>
      <% if (error?.stack) { %>
        <pre class="mt-6 text-left p-4 bg-gray-100 rounded overflow-x-auto text-xs text-red-600 shadow-inner"><%= error.stack %></pre>
      <% } %>
    </div>
    <div class="mt-8">
      <a href="/" class="inline-flex items-center justify-center px-5 py-3 border border-transparent text-base font-medium rounded-md text-white bg-green-600 hover:bg-green-700 shadow-sm transition duration-150 ease-in-out">
        Return Home
      </a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
