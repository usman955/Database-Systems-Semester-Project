<%- include('../partials/navbar') %>

<div class="mb-6 flex justify-between items-center">
  <h1 class="text-2xl font-bold text-gray-900">Manage Reports</h1>
  
  <div class="flex items-center space-x-2">
    <label for="statusFilter" class="text-sm font-medium text-gray-700">Filter:</label>
    <select id="statusFilter" class="shadow-sm focus:ring-green-500 focus:border-green-500 sm:text-sm border-gray-300 rounded-md py-1.5 px-3 border bg-white cursor-pointer" onchange="window.location.href='/admin/reports?status='+this.value">
      <option value="">All Statuses</option>
      <option value="Pending" <%= currentStatus === 'Pending' ? 'selected' : '' %>>Pending</option>
      <option value="In Progress" <%= currentStatus === 'In Progress' ? 'selected' : '' %>>In Progress</option>
      <option value="Resolved" <%= currentStatus === 'Resolved' ? 'selected' : '' %>>Resolved</option>
    </select>
  </div>
</div>

<div class="bg-white shadow overflow-hidden sm:rounded-lg border border-gray-100">
  <ul class="divide-y divide-gray-200">
    <% reports.forEach(report => { %>
      <li class="p-5 hover:bg-gray-50 transition duration-150 ease-in-out">
        <div class="flex flex-col md:flex-row md:items-center justify-between">
          <div class="flex-1 min-w-0 md:mr-4 mb-4 md:mb-0">
            <a href="/reports/<%= report.report_id %>" class="block focus:outline-none">
              <div class="flex items-center mb-2 flex-wrap">
                <p class="text-base font-medium text-green-700 mr-3 truncate max-w-full">
                  #<%= report.report_id %> <%= report.category_name %> at <%= report.location_name %>
                </p>
                <div class="flex-shrink-0 flex items-center space-x-2 mt-1 sm:mt-0">
                  <!-- Priority Badge -->
                  <% if (report.priority === 'High') { %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800 border border-red-200">High</span>
                  <% } else if (report.priority === 'Medium') { %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-orange-100 text-orange-800 border border-orange-200">Medium</span>
                  <% } else { %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800 border border-gray-200">Low</span>
                  <% } %>

                  <!-- Status Badge -->
                  <% if (report.status === 'Pending') { %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800 border border-yellow-200">Pending</span>
                  <% } else if (report.status === 'In Progress') { %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800 border border-blue-200">In Progress</span>
                  <% } else { %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800 border border-green-200">Resolved</span>
                  <% } %>
                </div>
              </div>
              <div class="sm:flex sm:justify-between text-sm text-gray-500">
                <p class="truncate max-w-xl"><%= report.description %></p>
                <div class="mt-2 sm:mt-0 flex space-x-4">
                  <p>By: <%= report.reporter_name %></p>
                  <p><%= new Date(report.created_at).toLocaleDateString() %></p>
                </div>
              </div>
            </a>
          </div>
          
          <div class="flex-shrink-0 md:border-l md:pl-4 border-gray-200">
            <form action="/admin/reports/<%= report.report_id %>/assign" method="POST" class="flex items-center space-x-2">
              <label for="assign_<%= report.report_id %>" class="sr-only">Assign To</label>
              <select id="assign_<%= report.report_id %>" name="assigned_to" class="shadow-sm focus:ring-green-500 focus:border-green-500 sm:text-sm border-gray-300 rounded-md py-1.5 px-3 border bg-white" <%= report.status === 'Resolved' ? 'disabled' : '' %>>
                <option value="">Unassigned</option>
                <% maintenanceUsers.forEach(mUser => { %>
                  <option value="<%= mUser.user_id %>" <%= report.assigned_to === mUser.user_id ? 'selected' : '' %>>
                    <%= mUser.name %>
                  </option>
                <% }) %>
              </select>
              <button type="submit" class="bg-white border border-gray-300 text-gray-700 px-3 py-1.5 rounded text-sm shadow-sm hover:bg-gray-50 transition duration-200" <%= report.status === 'Resolved' ? 'disabled' : '' %>>
                Assign
              </button>
            </form>
          </div>
        </div>
      </li>
    <% }) %>
    <% if (reports.length === 0) { %>
      <li class="p-8 text-center text-gray-500">
        <p class="text-lg">No reports found.</p>
      </li>
    <% } %>
  </ul>
</div>

<%- include('../partials/footer') %>
