<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Waste Reporting & Recycling Tracker</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    /* Custom styles */
    .btn-primary { @apply bg-green-600 text-white px-4 py-2 rounded shadow hover:bg-green-700 transition duration-200; }
  </style>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen font-sans">
  
  <nav class="bg-white shadow-md">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16">
        <div class="flex items-center">
          <a href="/" class="flex-shrink-0 flex items-center">
            <svg class="h-8 w-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="ml-2 text-xl font-bold text-gray-800">EcoTracker</span>
          </a>
          <div class="hidden sm:ml-6 sm:flex sm:space-x-8">
            <% if (locals.user) { %>
              <% if (locals.user.role === 'admin') { %>
                <a href="/admin/dashboard" class="border-transparent text-gray-500 hover:border-green-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Dashboard</a>
                <a href="/admin/reports" class="border-transparent text-gray-500 hover:border-green-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Manage Reports</a>
                <a href="/bins" class="border-transparent text-gray-500 hover:border-green-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Recycling Bins</a>
              <% } else if (locals.user.role === 'maintenance') { %>
                <a href="/maintenance/dashboard" class="border-transparent text-gray-500 hover:border-green-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Dashboard</a>
                <a href="/bins" class="border-transparent text-gray-500 hover:border-green-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Recycling Bins</a>
              <% } else if (locals.user.role === 'student') { %>
                <a href="/student/dashboard" class="border-transparent text-gray-500 hover:border-green-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">My Reports</a>
                <a href="/student/submit-report" class="border-transparent text-gray-500 hover:border-green-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Submit Report</a>
                <a href="/bins" class="border-transparent text-gray-500 hover:border-green-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Recycling Bins</a>
              <% } %>
            <% } %>
          </div>
        </div>
        <div class="flex items-center">
          <% if (locals.user) { %>
            <div class="relative flex items-center mr-4">
              <button id="notificationBtn" class="bg-white p-1 rounded-full text-gray-400 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                <span class="sr-only">View notifications</span>
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                </svg>
                <% if (locals.unreadNotifications > 0) { %>
                  <span class="absolute top-0 right-0 inline-flex items-center justify-center px-2 py-1 text-xs font-bold leading-none text-white transform translate-x-1/4 -translate-y-1/4 bg-red-600 rounded-full"><%= locals.unreadNotifications %></span>
                <% } %>
              </button>
            </div>
            <div class="ml-3 relative flex items-center">
              <span class="text-sm font-medium text-gray-700 mr-4"><%= locals.user.name %> (<%= locals.user.role %>)</span>
              <a href="/auth/logout" class="text-sm text-red-600 hover:text-red-800 font-medium">Logout</a>
            </div>
          <% } else { %>
            <a href="/auth/login" class="text-sm text-gray-700 hover:text-green-600 font-medium mr-4">Login</a>
            <a href="/auth/register" class="bg-green-600 text-white px-4 py-2 rounded shadow hover:bg-green-700 transition duration-200">Register</a>
          <% } %>
        </div>
      </div>
    </div>
  </nav>

  <% if (locals.success) { %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative shadow-sm" role="alert">
        <span class="block sm:inline"><%= locals.success %></span>
      </div>
    </div>
  <% } %>

  <% if (locals.error) { %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative shadow-sm" role="alert">
        <span class="block sm:inline"><%= locals.error %></span>
      </div>
    </div>
  <% } %>

  <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <script>
      // Handle notifications click
      document.getElementById('notificationBtn')?.addEventListener('click', () => {
        fetch('/notifications/read', { method: 'POST' })
          .then(res => res.json())
          .then(data => {
            if(data.success) {
              window.location.reload();
            }
          });
      });
    </script>
